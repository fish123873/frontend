NEXT_PUBLIC_API_URL=https://api.lumarahealth.shop
NEXT_PUBLIC_SITE_URL=https://lumarahealth.shop
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_SNAP_PIXEL_ID=

# MaxMind GeoIP2 Insights — used to block non-Morocco orders and VPN/proxy traffic
# Get credentials at https://www.maxmind.com/en/accounts/current/license-key
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
# Set to "false" to disable IP verification (e.g. for local dev)
MAXMIND_ENABLED=true
# Reserved for future minFraud integration
MAXMIND_RISK_THRESHOLD=75
