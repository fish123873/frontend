# MaxMind GeoIP2 Insights — used to block non-Morocco orders and VPN/proxy traffic
# Get credentials at https://www.maxmind.com/en/accounts/current/license-key
# LEAVE EMPTY to keep IP verification OFF (safe default — no orders blocked).
# To enable: fill both credentials AND set MAXMIND_ENABLED=true
MAXMIND_ACCOUNT_ID=
MAXMIND_LICENSE_KEY=
MAXMIND_ENABLED=false
MAXMIND_RISK_THRESHOLD=75
